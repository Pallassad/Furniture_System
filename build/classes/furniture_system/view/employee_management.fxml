<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  employee_management.fxml
  Controller: furniture_system.controller.EmployeeController
  Access: ADMIN only
-->
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.EmployeeController"
      spacing="12"
      style="-fx-background-color:#f5f6fa; -fx-padding:20 24 16 24;">

    <!-- ── Page header ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="👥 Employee Management"
               style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Statistics button -->
        <Button fx:id="btnStats" text="📊  Statistics"
                onAction="#handleStats"
                style="-fx-background-color:#7b1fa2;-fx-text-fill:white;
                       -fx-background-radius:6;-fx-padding:7 14;-fx-cursor:hand;"/>
    </HBox>

    <Separator/>

    <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <!-- Search -->
        <TextField fx:id="searchField"
                   promptText="🔍  Search by name / phone / email / position / status..."
                   prefWidth="380"
                   style="-fx-background-radius:6;-fx-border-color:#c5cae9;
                          -fx-border-radius:6;-fx-padding:6 10;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- Action buttons -->
        <Button fx:id="btnRefresh" text="⟳  Refresh"
                onAction="#handleRefresh"
                style="-fx-background-color:transparent;-fx-border-color:#3949ab;
                       -fx-border-radius:6;-fx-text-fill:#3949ab;
                       -fx-padding:7 14;-fx-cursor:hand;"/>
        <Button fx:id="btnAdd" text="➕  Add Employee"
                onAction="#handleAdd"
                style="-fx-background-color:#3949ab;-fx-text-fill:white;
                       -fx-background-radius:6;-fx-padding:7 14;
                       -fx-font-weight:bold;-fx-cursor:hand;"/>
        <Button fx:id="btnEdit" text="✏  Edit"
                onAction="#handleEdit"
                style="-fx-background-color:#f57c00;-fx-text-fill:white;
                       -fx-background-radius:6;-fx-padding:7 14;-fx-cursor:hand;"/>
        <Button fx:id="btnDelete" text="🗑  Remove"
                onAction="#handleDelete"
                style="-fx-background-color:#c62828;-fx-text-fill:white;
                       -fx-background-radius:6;-fx-padding:7 14;-fx-cursor:hand;"/>
    </HBox>

    <!-- ── Table ────────────────────────────────────────────────────────── -->
    <TableView fx:id="employeeTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white;-fx-border-color:#e0e0e0;
                      -fx-border-radius:6;-fx-background-radius:6;">
        <columns>
            <TableColumn fx:id="colId"       text="ID"         prefWidth="55"/>
            <TableColumn fx:id="colFullName" text="Full Name"  prefWidth="170"/>
            <TableColumn fx:id="colPhone"    text="Phone"      prefWidth="115"/>
            <TableColumn fx:id="colEmail"    text="Email"      prefWidth="185"/>
            <TableColumn fx:id="colPosition" text="Position"   prefWidth="110"/>
            <TableColumn fx:id="colStatus"   text="Status"     prefWidth="100"/>
            <TableColumn fx:id="colDob"      text="DOB"        prefWidth="100"/>
            <TableColumn fx:id="colAccount"  text="Account"    prefWidth="120"/>
            <TableColumn fx:id="colHiredAt"  text="Hired At"   prefWidth="145"/>
        </columns>
        <placeholder>
            <Label text="No employees found." style="-fx-text-fill:#9e9e9e;-fx-font-style:italic;"/>
        </placeholder>
    </TableView>

    <!-- ── Legend ───────────────────────────────────────────────────────── -->
    <HBox spacing="18" alignment="CENTER_LEFT"
          style="-fx-padding:4 0 0 4;">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label style="-fx-background-color:#ffe0e0;-fx-min-width:16px;-fx-min-height:16px;-fx-background-radius:3;"/>
            <Label text="SUSPENDED" style="-fx-font-size:11px;-fx-text-fill:#555;"/>
        </HBox>
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label style="-fx-background-color:#e8e8e8;-fx-min-width:16px;-fx-min-height:16px;-fx-background-radius:3;"/>
            <Label text="INACTIVE" style="-fx-font-size:11px;-fx-text-fill:#555;"/>
        </HBox>
    </HBox>

    <!-- ── Status bar ───────────────────────────────────────────────────── -->
    <HBox style="-fx-background-color:#e8eaf6;-fx-background-radius:4;-fx-padding:6 12;"
          alignment="CENTER_LEFT" spacing="6">
        <Label text="ℹ"/>
        <Label fx:id="statusBarLabel" text="Ready."
               style="-fx-text-fill:#37474f;-fx-font-size:12px;"/>
    </HBox>

</VBox>
