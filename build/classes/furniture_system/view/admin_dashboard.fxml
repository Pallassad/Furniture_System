<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="furniture_system.controller.AdminDashboardController"
            prefWidth="1100" prefHeight="680"
            style="-fx-background-color:#f5f6fa;">

    <!-- TOP NAV -->
    <top>
        <HBox style="-fx-background-color:#1a237e; -fx-padding:12 20;"
              spacing="16" alignment="CENTER_LEFT">
            <Label text="🪑 Fair Deal Furniture – Admin Dashboard"
                   style="-fx-text-fill:white; -fx-font-size:18px; -fx-font-weight:bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUsername"
                   text="Welcome, Admin"
                   style="-fx-text-fill:#c5cae9; -fx-font-size:13px;"/>
            <Button text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color:#ef5350; -fx-text-fill:white;
                           -fx-background-radius:6; -fx-cursor:hand;"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color:#283593; -fx-pref-width:210px;"
              spacing="2">
            <padding><Insets top="16" right="8" bottom="16" left="8"/></padding>
            <Label text="MENU" style="-fx-text-fill:#9fa8da; -fx-font-size:11px;
                                      -fx-padding:0 0 8 8;"/>

            <Button fx:id="btnAuth" text="🔐  Auth &amp; Authorization"
                    onAction="#showAuthManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:#3949ab; -fx-text-fill:white;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;
                           -fx-font-weight:bold;"/>

            <Button fx:id="btnEmployee" text="👥  Employee Management"
                    onAction="#showEmployeeManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnCustomer" text="👤  Customer Management"
                    onAction="#showCustomerManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnProduct" text="📦  Product Management"
                    onAction="#showProductManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnFurnitureType" text="🪑  Furniture Types"
                    onAction="#showFurnitureTypeManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnOrders" text="🛒  Orders"
                    onAction="#showOrders"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <!-- ★ MỚI -->
            <Button fx:id="btnPromotion" text="🎫  Promotion Management"
                    onAction="#showPromotionManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnSupplier" text="🏭  Supplier Management"
                    onAction="#showSupplierManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnStock" text="📋  Stock and Inventory"
                    onAction="#showStockManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnSalary" text="💰  Salary Management"
                    onAction="#showSalaryManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnWarranty" text="🔧  Warranty &amp; Repair"
                    onAction="#showWarrantyManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnDeliveryAddress" text="📍  Delivery Addresses"
                    onAction="#showDeliveryAddressManagement"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>

            <Button fx:id="btnReports" text="📊  Reports"
                    onAction="#showReports"
                    maxWidth="Infinity"
                    style="-fx-background-color:transparent; -fx-text-fill:#c5cae9;
                           -fx-background-radius:6; -fx-cursor:hand;
                           -fx-alignment:CENTER_LEFT; -fx-padding:10 12;"/>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>
