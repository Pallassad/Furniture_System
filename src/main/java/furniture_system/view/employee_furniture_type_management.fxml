<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.EmployeeFurnitureTypeController"
      styleClass="content-root"
      stylesheets="@../resources/css/emp.css"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🪑 Furniture Types" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRefresh"    text="⟳  Refresh"      onAction="#handleRefresh"    styleClass="btn-outline"/>
        <Button fx:id="btnViewDetail" text="🔍  View Details" onAction="#handleViewDetail" styleClass="btn-teal" disable="true"/>
    </HBox>
    <Separator styleClass="separator"/>

    <!-- Type Filter + Search Row -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Filter by type:" style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"/>
        <ComboBox fx:id="cmbTypeFilter"
                  promptText="All Types"
                  prefWidth="200"
                  onAction="#handleSearch"
                  styleClass="combo-box"/>
        <TextField fx:id="txtProductSearch"
                   promptText="🔍  Search product name..."
                   prefWidth="260"
                   styleClass="login-field"/>
        <Button text="Search" onAction="#handleSearch" styleClass="btn-primary"/>
    </HBox>

    <!-- Table (read-only) -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

      <TableView fx:id="productTable" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colProductId"     text="ID"           prefWidth="55"/>
            <TableColumn fx:id="colProductName"   text="Product Name" prefWidth="250"/>
            <TableColumn fx:id="colProductType"   text="Type"         prefWidth="160"/>
            <TableColumn fx:id="colProductPrice"  text="Price (VND)"  prefWidth="140"/>
            <TableColumn fx:id="colProductStatus" text="Status"       prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="No products found for this type." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    </ScrollPane>

    <!-- Status Bar -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="6">
        <Label text="ℹ"/>
        <Label fx:id="statusBarLabel" text="Ready." styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="🔒 View only — browse products by furniture category."
               style="-fx-font-size:11px; -fx-text-fill:#888;"/>
    </HBox>
</VBox>
