<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx"
      fx:controller="furniture_system.controller.StockController"
      stylesheets="@../resources/css/admin.css" spacing="0"
      style="-fx-background-color:#eef0f5;">

  <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:20 28 14 28;">
    <Label styleClass="page-title" text="📈  Stock &amp; Inventory" HBox.hgrow="ALWAYS"/>
    <Button fx:id="btnStockIn" styleClass="btn-primary" text="📥  Stock In"  onAction="#handleStockIn"/>
    <Button fx:id="btnAdjust"  styleClass="btn-warning" text="⚙  Adjust"    onAction="#handleAdjust"/>
    <Button                    styleClass="btn-outline" text="⟳  Refresh"   onAction="#handleRefreshStock"/>
  </HBox>
  <Separator style="-fx-background-color:#d8dce8;"/>

  <SplitPane orientation="VERTICAL" VBox.vgrow="ALWAYS"
             style="-fx-padding:0 28 14 28; -fx-background-color:transparent;">

    <!-- Stock levels -->
    <VBox styleClass="table-card" minHeight="180">
      <Label styleClass="sub-heading-label" text="📦  Current Stock Levels" maxWidth="Infinity"/>
        <TableView VBox.vgrow="ALWAYS" fx:id="tblStock" styleClass="table-view">
        <columns>
          <TableColumn fx:id="colStockProduct" text="Product"      prefWidth="260"/>
          <TableColumn fx:id="colStockQty"     text="Qty"          prefWidth="90"/>
          <TableColumn fx:id="colStockReorder" text="Reorder Pt."  prefWidth="110"/>
          <TableColumn fx:id="colStockUpdated" text="Last Updated" prefWidth="155"/>
          <TableColumn fx:id="colStockAlert"   text="Alert"        prefWidth="120"/>
        </columns>
        <placeholder><Label text="No stock data." style="-fx-text-fill:#8a93b2;"/></placeholder>
      </TableView>
      <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ" style="-fx-text-fill:#4a7cff;"/>
        <Label fx:id="lblStatus" styleClass="status-bar-label" text="Loading…"/>
      </HBox>
    </VBox>

    <!-- Movement log -->
    <VBox styleClass="table-card" minHeight="160">
      <Label styleClass="sub-heading-label" text="📋  Stock Movement Log" maxWidth="Infinity"/>
      <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding:8 12 6 12;">
        <ComboBox fx:id="cbLogProduct" styleClass="filter-combo" promptText="All Products" prefWidth="170"/>
        <ComboBox fx:id="cbLogType"    styleClass="filter-combo" promptText="All Types"    prefWidth="120"/>
        <DatePicker fx:id="dpFrom"     styleClass="filter-date"  promptText="From"         prefWidth="130"/>
        <DatePicker fx:id="dpTo"       styleClass="filter-date"  promptText="To"           prefWidth="130"/>
        <Button styleClass="btn-primary" text="Filter" onAction="#handleFilterLog"
                style="-fx-padding:6 12 6 12;"/>
        <Button styleClass="btn-outline" text="Clear"  onAction="#handleClearFilter"
                style="-fx-padding:6 12 6 12;"/>
      </HBox>
      <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">
  <TableView fx:id="tblLog" styleClass="table-view" style="-fx-hbar-policy:never;">
        <columns>
          <TableColumn fx:id="colLogId"      text="ID"      prefWidth="50"/>
          <TableColumn fx:id="colLogProduct" text="Product" prefWidth="200"/>
          <TableColumn fx:id="colLogQty"     text="Qty"     prefWidth="70"/>
          <TableColumn fx:id="colLogType"    text="Type"    prefWidth="100"/>
          <TableColumn fx:id="colLogNote"    text="Note"    prefWidth="200"/>
          <TableColumn fx:id="colLogActor"   text="Actor"   prefWidth="100"/>
          <TableColumn fx:id="colLogDate"    text="Date"    prefWidth="155"/>
        </columns>
        <placeholder><Label text="No log entries." style="-fx-text-fill:#8a93b2;"/></placeholder>
      </TableView>
</ScrollPane>
    </VBox>
  </SplitPane>
</VBox>
