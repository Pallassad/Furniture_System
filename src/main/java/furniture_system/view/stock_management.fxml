<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.StockController"
      stylesheets="@/furniture_system/resources/css/admin.css"
      styleClass="content-root"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- ── Page Header ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="📦 Stock &amp; Inventory Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnStockIn"   text="📥  Stock In"     onAction="#handleStockIn"     styleClass="btn-success"/>
        <Button fx:id="btnAdjust"    text="⚖  Adjust Stock"  onAction="#handleAdjust"      styleClass="btn-warning"/>
        
        <Button                      text="⟳  Refresh"       onAction="#handleRefreshStock" styleClass="btn-outline"/>
    </HBox>

    <Separator styleClass="separator"/>

    <!-- ── TabPane ──────────────────────────────────────────────────────── -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE"
             style="-fx-tab-min-width:160px;">

        <!-- ═══ TAB 1: Stock Levels ═══════════════════════════════════════ -->
        <Tab text="📊  Stock Levels">
            <VBox spacing="10" style="-fx-padding:14 0 0 0;">
                <Label text="⚠ Rows highlighted in orange are below reorder level."
                       style="-fx-font-size:11px;-fx-text-fill:#e65100;"/>
                <TableView fx:id="tblStock" VBox.vgrow="ALWAYS" styleClass="table-view"
                           tableMenuButtonVisible="true">
                    <columns>
                        <TableColumn fx:id="colStockProduct" text="Product"       prefWidth="320"/>
                        <TableColumn fx:id="colStockQty"     text="In Stock"      prefWidth="110"/>
                        <TableColumn fx:id="colStockReorder" text="Reorder Level" prefWidth="130"/>
                        <TableColumn fx:id="colStockUpdated" text="Last Updated"  prefWidth="185"/>
                        <TableColumn fx:id="colStockAlert"   text="Status"        prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <Label text="No stock data found." styleClass="table-placeholder"/>
                    </placeholder>
                </TableView>
            </VBox>
        </Tab>

        <!-- ═══ TAB 2: Movement Log ════════════════════════════════════════ -->
        <Tab text="📋  Movement Log">
            <VBox spacing="10" style="-fx-padding:14 0 0 0;">

                <!-- Filter: label trên, control dưới, nút bên phải -->
                <HBox spacing="12" alignment="BOTTOM_LEFT">
                    <VBox spacing="3">
                        <Label text="Product" style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#7986cb;"/>
                        <ComboBox fx:id="cbLogProduct" prefWidth="200" promptText="All products" styleClass="combo-box"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="Type" style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#7986cb;"/>
                        <ComboBox fx:id="cbLogType" prefWidth="150" styleClass="combo-box"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="From" style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#7986cb;"/>
                        <DatePicker fx:id="dpFrom" prefWidth="150" styleClass="date-picker"/>
                    </VBox>
                    <VBox spacing="3">
                        <Label text="To" style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#7986cb;"/>
                        <DatePicker fx:id="dpTo" prefWidth="150" styleClass="date-picker"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="🔍  Filter" onAction="#handleFilterLog"   styleClass="btn-primary"/>
                    <Button text="Clear"      onAction="#handleClearFilter" styleClass="btn-outline"/>
                </HBox>

                <TableView fx:id="tblLog" VBox.vgrow="ALWAYS" styleClass="table-view"
                           tableMenuButtonVisible="true">
                    <columns>
                        <TableColumn fx:id="colLogId"      text="ID"      prefWidth="55"/>
                        <TableColumn fx:id="colLogProduct" text="Product" prefWidth="210"/>
                        <TableColumn fx:id="colLogQty"     text="Δ Qty"   prefWidth="75"/>
                        <TableColumn fx:id="colLogType"    text="Type"    prefWidth="120"/>
                        <TableColumn fx:id="colLogNote"    text="Note"    prefWidth="210"/>
                        <TableColumn fx:id="colLogActor"   text="Actor"   prefWidth="130"/>
                        <TableColumn fx:id="colLogDate"    text="Date"    prefWidth="165"/>
                    </columns>
                    <placeholder>
                        <Label text="No log entries found." styleClass="table-placeholder"/>
                    </placeholder>
                </TableView>


            </VBox>
        </Tab>

    </TabPane>

    <!-- ── Status Bar ───────────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ"/>
        <Label fx:id="lblStatus" text="Ready." styleClass="status-label"/>
    </HBox>
</VBox>
