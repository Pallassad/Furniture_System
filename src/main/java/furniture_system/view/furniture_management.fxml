<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.AdminFurnitureController"
      stylesheets="@/furniture_system/resources/css/admin.css"
      styleClass="content-root"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- ── Page Header ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🛋 Furniture Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAdd"        text="➕  Add Product"    onAction="#handleAdd"        styleClass="btn-primary"/>
        <Button fx:id="btnEdit"       text="✏  Edit Product"   onAction="#handleEdit"       styleClass="btn-warning"/>
        <Button fx:id="btnDeactivate" text="🚫  Deactivate"     onAction="#handleDeactivate" styleClass="btn-danger"/>
        <Button fx:id="btnDelete"     text="🗑  Delete permanently" onAction="#handleDelete"      styleClass="btn-danger"/>
        <Button fx:id="btnRefresh"    text="⟳  Refresh"        onAction="#handleRefresh"    styleClass="btn-outline"/>
    </HBox>

    <Separator styleClass="separator"/>

    <!-- ── Search Bar ───────────────────────────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" styleClass="login-field"
                   promptText="🔍 Search by name / type / supplier / status / ID…"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#handleSearch"  styleClass="btn-primary"/>
        <Button text="Clear"  onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>

    <!-- ── Product Table ────────────────────────────────────────────────── -->
    <TableView fx:id="productTable" VBox.vgrow="ALWAYS" styleClass="table-view"
               tableMenuButtonVisible="true">
        <columns>
            <TableColumn fx:id="colId"       text="ID"              prefWidth="55"/>
            <TableColumn fx:id="colName"     text="Product Name"    prefWidth="220"/>
            <TableColumn fx:id="colType"     text="Category"        prefWidth="140"/>
            <TableColumn fx:id="colSupplier" text="Supplier"        prefWidth="160"/>
            <TableColumn fx:id="colPrice"    text="Price"           prefWidth="130"/>
            <TableColumn fx:id="colWarranty" text="Warranty (mo)"   prefWidth="110"/>
            <TableColumn fx:id="colStatus"   text="Status"          prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="No products found." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status Bar ───────────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ"/>
        <Label fx:id="statusBarLabel" text="Ready." styleClass="status-label"/>
    </HBox>
</VBox>
