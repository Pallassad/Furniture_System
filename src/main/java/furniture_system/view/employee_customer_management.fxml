<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.CustomerController"
      spacing="14"
      styleClass="content-root"
      stylesheets="@../resources/css/emp.css">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- ── Page Header ──────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="👤 Customer Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <!-- btnStats ẩn với Employee (isAdmin=false → setVisible(false) trong controller) -->
        <Button fx:id="btnStats" text="📊  Statistics" onAction="#handleStats" styleClass="btn-purple"/>
    </HBox>
    <Separator styleClass="separator"/>

    <!-- ── Toolbar ──────────────────────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="🔍  Search by name / phone / email..."
                   prefWidth="380"
                   styleClass="login-field"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRefresh" text="⟳  Refresh"          onAction="#handleRefresh"  styleClass="btn-outline"/>
        <!-- btnAdd hiển thị với cả Employee (createCustomer) -->
        <Button fx:id="btnAdd"     text="➕  Add Customer"     onAction="#handleAdd"      styleClass="btn-primary"/>
        <!-- btnEdit / btnDelete: controller sẽ setVisible(false) khi isAdmin=false -->
        <Button fx:id="btnEdit"    text="✏  Edit"              onAction="#handleEdit"     styleClass="btn-warning"/>
        <Button fx:id="btnDelete"  text="🗑  Remove"           onAction="#handleDelete"   styleClass="btn-danger"/>
        <Button fx:id="btnHistory" text="🛒  Purchase History" onAction="#handleHistory"  styleClass="btn-teal"/>
    </HBox>

    <!-- ── Table ────────────────────────────────────────────────── -->
    <TableView fx:id="customerTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="colId"        text="ID"         prefWidth="60"/>
            <TableColumn fx:id="colFullName"  text="Full Name"  prefWidth="190"/>
            <TableColumn fx:id="colPhone"     text="Phone"      prefWidth="120"/>
            <TableColumn fx:id="colEmail"     text="Email"      prefWidth="200"/>
            <TableColumn fx:id="colGender"    text="Gender"     prefWidth="90"/>
            <TableColumn fx:id="colStatus"    text="Status"     prefWidth="90"/>
            <TableColumn fx:id="colCreatedAt" text="Created At" prefWidth="145"/>
        </columns>
        <placeholder>
            <Label text="No customers found." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status Bar ───────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="6">
        <Label text="ℹ"/>
        <Label fx:id="statusBarLabel" text="Ready." styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="💡 Double-click a row to view purchase history."
               style="-fx-font-size:11px;-fx-text-fill:#888;"/>
    </HBox>
</VBox>
