<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.EmployeeWarrantyController"
      stylesheets="@/furniture_system/resources/css/emp.css"
      styleClass="content-root"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- ── Page Header ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🔧 Warranty &amp; Repair Tickets" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnCreate" text="➕  Create Ticket"  onAction="#handleCreate" styleClass="btn-primary"/>
        <Button fx:id="btnUpdate" text="✏  Update Status"  onAction="#handleUpdate" styleClass="btn-warning"/>
        <Button                   text="⟳  Refresh"        onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>

    <Separator styleClass="separator"/>

    <!-- ── Info hint ────────────────────────────────────────────────────── -->
    <Label text="Showing tickets assigned to you. Double-click a row to update status."
           style="-fx-font-size:11px;-fx-text-fill:#888;-fx-font-style:italic;"/>

    <!-- ── Warranty Table ───────────────────────────────────────────────── -->
    <TableView fx:id="tableWarranty" VBox.vgrow="ALWAYS" styleClass="table-view"
               tableMenuButtonVisible="true">
        <columns>
            <TableColumn fx:id="colTicketId"  text="#"        prefWidth="55"/>
            <TableColumn fx:id="colOrderId"   text="Order"    prefWidth="70"/>
            <TableColumn fx:id="colProduct"   text="Product"  prefWidth="240"/>
            <TableColumn fx:id="colCustomer"  text="Customer" prefWidth="175"/>
            <TableColumn fx:id="colStatus"    text="Status"   prefWidth="130"/>
            <TableColumn fx:id="colCost"      text="Cost"     prefWidth="120"/>
            <TableColumn fx:id="colCreatedAt" text="Created"  prefWidth="110"/>
        </columns>
        <placeholder>
            <Label text="No assigned tickets found." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status Bar ───────────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ"/>
        <Label fx:id="lblEmpStatus" text="Ready." styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="💡 Cost = 0 → Free warranty   |   Cost &gt; 0 → Chargeable repair"
               style="-fx-font-size:11px;-fx-text-fill:#888;"/>
    </HBox>
</VBox>
