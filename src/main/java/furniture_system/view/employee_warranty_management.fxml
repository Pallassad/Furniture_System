<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.EmployeeWarrantyController"
      styleClass="content-root"
      stylesheets="@../resources/css/emp.css"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🔧 Warranty &amp; Repair" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="⟳  Refresh"      onAction="#handleRefresh" styleClass="btn-outline"/>
        <Button fx:id="btnCreate"
                text="➕  Create Ticket"
                onAction="#handleCreate"
                styleClass="btn-primary"/>
        <Button fx:id="btnUpdate"
                text="✏  Update Status"
                onAction="#handleUpdate"
                styleClass="btn-warning"
                disable="true"/>
    </HBox>
    <Separator styleClass="separator"/>

    <!-- Table -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

      <TableView fx:id="tableWarranty" styleClass="table-view" style="-fx-hbar-policy:never;">
        <columns>
            <TableColumn fx:id="colTicketId"  text="Ticket ID" prefWidth="90"/>
            <TableColumn fx:id="colOrderId"   text="Order ID"  prefWidth="90"/>
            <TableColumn fx:id="colProduct"   text="Product"   prefWidth="210"/>
            <TableColumn fx:id="colCustomer"  text="Customer"  prefWidth="170"/>
            <TableColumn fx:id="colStatus"    text="Status"    prefWidth="130"/>
            <TableColumn fx:id="colCost"      text="Cost (VND)" prefWidth="120"/>
            <TableColumn fx:id="colCreatedAt" text="Created At" prefWidth="155"/>
        </columns>
        <placeholder>
            <Label text="No warranty tickets found." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    </ScrollPane>

    <!-- Status Bar -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="6">
        <Label text="ℹ"/>
        <Label fx:id="lblEmpStatus" text="Ready." styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="💡 Select a ticket to enable Update Status."
               style="-fx-font-size:11px; -fx-text-fill:#888;"/>
    </HBox>
</VBox>
