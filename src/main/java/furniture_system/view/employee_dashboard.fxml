<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="furniture_system.controller.EmployeeDashboardController"
            stylesheets="@../resources/css/emp.css"
            style="-fx-background-color:#f0f4f0;"
            prefWidth="1280" prefHeight="760">

    <!-- TOPBAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16" prefHeight="58">
        
            <Region styleClass="topbar-logo" prefWidth="22" prefHeight="22"/>
            <Label styleClass="topbar-title" 
                   text="Fair Deal – Employee Portal" 
                   HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER_RIGHT" spacing="14" HBox.hgrow="NEVER">
                <Label styleClass="topbar-role" text="EMPLOYEE"/>
                <Label fx:id="lblUsername" 
                       styleClass="topbar-welcome" 
                       text="Welcome, Huy"/>
                <Button styleClass="btn-logout" 
                        text="Logout" 
                        onAction="#handleLogout"/>
            </HBox>
        
        </HBox>
    </top>

    <!-- ══ SIDEBAR ══════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar-emp" spacing="2"
              prefWidth="220" minWidth="220">
            <padding>
                <Insets top="16" right="8" bottom="16" left="8"/>
            </padding>

            <Label styleClass="menu-label" text="MENU"
                   style="-fx-padding:0 0 8 8;"/>

            <Button fx:id="btnCustomer"
                    styleClass="nav-btn"
                    text="👤  Customers"
                    onAction="#showCustomerManagement"
                    maxWidth="Infinity"/>

            <Button fx:id="btnOrders"
                    styleClass="nav-btn"
                    text="🛒  Sales / Orders"
                    onAction="#showOrders"
                    maxWidth="Infinity"/>

            <Button fx:id="btnFurnitureType"
                    styleClass="nav-btn"
                    text="🏷️  Furniture Types"
                    onAction="#showFurnitureTypeFilter"
                    maxWidth="Infinity"/>

            <Button fx:id="btnProducts"
                    styleClass="nav-btn"
                    text="📋  Furniture"
                    onAction="#showProducts"
                    maxWidth="Infinity"/>

            <Button fx:id="btnInventory"
                    styleClass="nav-btn"
                    text="📦  Inventory Check"
                    onAction="#showInventory"
                    maxWidth="Infinity"/>

            <Button fx:id="btnPromotion"
                    styleClass="nav-btn"
                    text="🎫  Promotions"
                    onAction="#showPromotions"
                    maxWidth="Infinity"/>

            <Button fx:id="btnDeliveryAddress"
                    styleClass="nav-btn"
                    text="📍  Delivery Addresses"
                    onAction="#showDeliveryAddressManagement"
                    maxWidth="Infinity"/>

            <Button fx:id="btnSalary"
                    styleClass="nav-btn"
                    text="💰  Salary Management"
                    onAction="#showSalaryManagement"
                    maxWidth="Infinity"/>

            <Button fx:id="btnWarranty"
                    styleClass="nav-btn"
                    text="🔧  Warranty Tickets"
                    onAction="#showWarranty"
                    maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- ══ CONTENT AREA ═════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea" id="contentArea"
                   style="-fx-background-color:#f0f4f0;"/>
    </center>

</BorderPane>
