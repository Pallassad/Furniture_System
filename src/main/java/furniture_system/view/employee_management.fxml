<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx"
      fx:controller="furniture_system.controller.EmployeeController"
      stylesheets="@../resources/css/admin.css" spacing="0"
      style="-fx-background-color:#eef0f5;">

  <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:20 28 14 28;">
    <Label styleClass="page-title" text="👥  Employee Management" HBox.hgrow="ALWAYS"/>
    <Button fx:id="btnAdd"     styleClass="btn-primary" text="➕  Add"     onAction="#handleAdd"/>
    <Button fx:id="btnEdit"    styleClass="btn-warning" text="✏  Edit"    onAction="#handleEdit"   disable="true"/>
    <Button fx:id="btnDelete"  styleClass="btn-danger"  text="🗑  Delete"  onAction="#handleDelete" disable="true"/>
    <Button fx:id="btnStats"   styleClass="btn-success" text="📊  Stats"   onAction="#handleStats"/>
    <Button fx:id="btnRefresh" styleClass="btn-outline" text="⟳  Refresh" onAction="#handleRefresh"/>
  </HBox>
  <Separator style="-fx-background-color:#d8dce8;"/>

  <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding:10 28 8 28;">
    <TextField fx:id="searchField" styleClass="search-field"
               promptText="Search by name, phone, email…" prefWidth="320"/>
    <Button styleClass="btn-primary" text="Search" onAction="#handleSearch"
            style="-fx-padding:7 14 7 14;"/>
  </HBox>

  <VBox VBox.vgrow="ALWAYS" style="-fx-padding:0 28 14 28;">
    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
      <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

        <TableView fx:id="employeeTable" styleClass="table-view" style="-fx-hbar-policy:never;">
        <columns>
          <TableColumn fx:id="colId"        text="ID"          prefWidth="50"/>
          <TableColumn fx:id="colFullName"  text="Full Name"   prefWidth="160"/>
          <TableColumn fx:id="colPhone"     text="Phone"       prefWidth="120"/>
          <TableColumn fx:id="colEmail"     text="Email"       prefWidth="190"/>
          <TableColumn fx:id="colPosition"  text="Position"    prefWidth="120"/>
          <TableColumn fx:id="colStatus"    text="Status"      prefWidth="110"/>
          <TableColumn fx:id="colDob"       text="Date of Birth" prefWidth="110"/>
          <TableColumn fx:id="colAccount"   text="Account"     prefWidth="120"/>
          <TableColumn fx:id="colHiredAt"   text="Hired At"    prefWidth="155"/>
        </columns>
        <placeholder><Label text="No employees found." style="-fx-text-fill:#8a93b2;"/></placeholder>
      </TableView>

      </ScrollPane>
      <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ" style="-fx-text-fill:#4a7cff;"/>
        <Label fx:id="statusBarLabel" styleClass="status-bar-label" text="Loading…"/>
      </HBox>
    </VBox>
  </VBox>
</VBox>
