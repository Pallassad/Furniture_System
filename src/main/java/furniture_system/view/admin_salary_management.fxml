<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx"
      fx:controller="furniture_system.controller.AdminSalaryManagementController"
      stylesheets="@../resources/css/admin.css" spacing="0"
      style="-fx-background-color:#eef0f5;">

  <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:20 28 14 28;">
    <Label styleClass="page-title" text="💰  Salary Management"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button styleClass="btn-primary" text="➕  Add Record" onAction="#handleAdd"    fx:id="btnAdd"/>
    <Button styleClass="btn-warning" text="✏  Edit"       onAction="#handleEdit"   fx:id="btnEdit"   disable="true"/>
    <Button styleClass="btn-danger"  text="🗑  Delete"     onAction="#handleDelete" fx:id="btnDelete" disable="true"/>
    <Button styleClass="btn-outline" text="⟳  Refresh"    onAction="#handleRefresh"/>
  </HBox>
  <Separator style="-fx-background-color:#d8dce8;"/>

  <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding:10 28 8 28;">
    <TextField fx:id="txtSearch" styleClass="search-field"
               promptText="Search by employee name…" prefWidth="280"/>
    <Button styleClass="btn-primary" text="Search" onAction="#handleSearch"
            style="-fx-padding:7 14 7 14;"/>
  </HBox>

  <VBox VBox.vgrow="ALWAYS" style="-fx-padding:0 28 14 28;">
    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
      <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

        <TableView fx:id="tableSalary" styleClass="table-view" style="-fx-hbar-policy:never;">
        <columns>
          <TableColumn fx:id="colSalaryId"     text="ID"             prefWidth="50"/>
          <TableColumn fx:id="colEmployee"     text="Employee"       prefWidth="160"/>
          <TableColumn fx:id="colMonth"        text="Month"          prefWidth="90"/>
          <TableColumn fx:id="colBase"         text="Base (VND)"     prefWidth="120"/>
          <TableColumn fx:id="colAllowance"    text="Allowance"      prefWidth="120"/>
          <TableColumn fx:id="colBonus"        text="Bonus"          prefWidth="100"/>
          <TableColumn fx:id="colDeduction"    text="Deduction"      prefWidth="110"/>
          <TableColumn fx:id="colFinal"        text="Final (VND)"    prefWidth="125"/>
          <TableColumn fx:id="colSalaryStatus" text="Status"         prefWidth="110"/>
          <TableColumn fx:id="colPaidDate"     text="Paid Date"      prefWidth="120"/>
        </columns>
        <placeholder><Label text="No salary records found." style="-fx-text-fill:#8a93b2;"/></placeholder>
      </TableView>

      </ScrollPane>
      <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ" style="-fx-text-fill:#4a7cff;-fx-font-size:14px;"/>
        <Label fx:id="lblSalaryStatus" styleClass="status-bar-label" text="Loading…"/>
      </HBox>
    </VBox>
  </VBox>
</VBox>
