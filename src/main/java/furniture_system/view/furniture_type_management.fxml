<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.FurnitureTypeController"
      stylesheets="@/furniture_system/resources/css/admin.css"
      styleClass="content-root"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- ── Page Header ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🪑 Furniture Types" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAdd"     text="➕  Add Type"   onAction="#handleAdd"     styleClass="btn-primary"/>
        <Button fx:id="btnEdit"    text="✏  Edit Type"   onAction="#handleEdit"    styleClass="btn-warning"/>
        <Button fx:id="btnDelete"  text="🗑  Delete"      onAction="#handleDelete"  styleClass="btn-danger"/>
        <Button fx:id="btnRefresh" text="⟳  Refresh"     onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>

    <Separator styleClass="separator"/>

    <!-- ── Search Bar ───────────────────────────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" styleClass="login-field"
                   promptText="🔍 Search by name, ID, or status…"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#handleSearch"  styleClass="btn-primary"/>
        <Button text="Clear"  onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>

    <!-- ── Furniture Type Table ─────────────────────────────────────────── -->
    <TableView fx:id="typeTable" VBox.vgrow="ALWAYS" styleClass="table-view"
               tableMenuButtonVisible="true">
        <columns>
            <TableColumn fx:id="colId"          text="ID"           prefWidth="55"/>
            <TableColumn fx:id="colName"        text="Type Name"    prefWidth="210"/>
            <TableColumn fx:id="colDescription" text="Description"  prefWidth="340"/>
            <TableColumn fx:id="colStatus"      text="Status"       prefWidth="110"/>
            <TableColumn fx:id="colCreatedAt"   text="Created Date" prefWidth="150"/>
        </columns>
        <placeholder>
            <Label text="No furniture types found." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status Bar ───────────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ"/>
        <Label fx:id="statusBarLabel" text="Ready." styleClass="status-label"/>
    </HBox>
</VBox>
