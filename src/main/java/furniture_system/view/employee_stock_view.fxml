<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.EmployeeStockController"
      stylesheets="@/furniture_system/resources/css/emp.css"
      styleClass="content-root"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- ── Page Header ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="📦 Inventory Check" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnCheckAvail" text="🔍  Check Availability" onAction="#handleCheckAvailability" styleClass="btn-primary"/>
        <Button                       text="⟳  Refresh"            onAction="#handleRefresh"           styleClass="btn-outline"/>
    </HBox>

    <Separator styleClass="separator"/>

    <!-- ── Search Bar ───────────────────────────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" styleClass="login-field"
                   promptText="🔍 Search by product name…"
                   HBox.hgrow="ALWAYS"/>
        <Button text="Search" onAction="#handleSearch"  styleClass="btn-primary"/>
        <Button text="Reset"  onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>

    <!-- ── Stock hint ───────────────────────────────────────────────────── -->
    <Label text="⚠ Rows highlighted in orange are below reorder level — notify admin."
           style="-fx-font-size:11px;-fx-text-fill:#e65100;"/>

    <!-- ── Stock Table ──────────────────────────────────────────────────── -->
    <TableView fx:id="tblStock" VBox.vgrow="ALWAYS" styleClass="table-view"
               tableMenuButtonVisible="true">
        <columns>
            <TableColumn fx:id="colProduct" text="Product"       prefWidth="320"/>
            <TableColumn fx:id="colQty"     text="In Stock"      prefWidth="110"/>
            <TableColumn fx:id="colReorder" text="Reorder Level" prefWidth="130"/>
            <TableColumn fx:id="colUpdated" text="Last Updated"  prefWidth="180"/>
            <TableColumn fx:id="colAlert"   text="Availability"  prefWidth="130"/>
        </columns>
        <placeholder>
            <Label text="No stock data available." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status Bar ───────────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ"/>
        <Label fx:id="lblStatus" text="Ready." styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="💡 Select a row then click Check Availability to check stock for an order."
               style="-fx-font-size:11px;-fx-text-fill:#888;"/>
    </HBox>
</VBox>
