<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.EmployeeFurnitureController"
      styleClass="content-root"
      stylesheets="@../resources/css/emp.css"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- Page Header -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🛋 Furniture Catalog" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnRefresh"    text="⟳  Refresh"      onAction="#handleRefresh"    styleClass="btn-outline"/>
        <Button fx:id="btnViewDetail" text="🔍  View Details" onAction="#handleViewDetail" styleClass="btn-teal" disable="true"/>
    </HBox>
    <Separator styleClass="separator"/>

    <!-- Search + Price Filter Row -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch"
                   promptText="🔍  Search by name or type..."
                   prefWidth="280"
                   styleClass="login-field"/>
        <Label text="Price:" style="-fx-font-size:12px; -fx-text-fill:#555;"/>
        <TextField fx:id="txtMinPrice"
                   promptText="Min"
                   prefWidth="90"
                   styleClass="search-field"/>
        <Label text="–" style="-fx-text-fill:#888;"/>
        <TextField fx:id="txtMaxPrice"
                   promptText="Max"
                   prefWidth="90"
                   styleClass="search-field"/>
        <Button text="Apply" onAction="#handleSearch" styleClass="btn-primary"/>
    </HBox>

    <!-- Table (read-only — active products only) -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

      <TableView fx:id="productTable" styleClass="table-view" style="-fx-hbar-policy:never;">
        <columns>
            <TableColumn fx:id="colId"       text="ID"             prefWidth="55"/>
            <TableColumn fx:id="colName"     text="Product Name"   prefWidth="220"/>
            <TableColumn fx:id="colType"     text="Type"           prefWidth="130"/>
            <TableColumn fx:id="colSupplier" text="Supplier"       prefWidth="160"/>
            <TableColumn fx:id="colPrice"    text="Price (VND)"    prefWidth="130"/>
            <TableColumn fx:id="colWarranty" text="Warranty (mo.)" prefWidth="120"/>
            <TableColumn fx:id="colStatus"   text="Status"         prefWidth="100"/>
        </columns>
        <placeholder>
            <Label text="No products found." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    </ScrollPane>

    <!-- Status Bar -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="6">
        <Label text="ℹ"/>
        <Label fx:id="statusBarLabel" text="Ready." styleClass="status-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="🔒 View only — active products shown."
               style="-fx-font-size:11px; -fx-text-fill:#888;"/>
    </HBox>
</VBox>
