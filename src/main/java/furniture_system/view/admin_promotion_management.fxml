<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx"
      fx:controller="furniture_system.controller.AdminPromotionController"
      stylesheets="@../resources/css/admin.css" spacing="0"
      style="-fx-background-color:#eef0f5;">

  <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:20 28 14 28;">
    <Label styleClass="page-title" text="🏷  Promotion Management"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button styleClass="btn-primary" text="➕  Add"     onAction="#handleAdd"    fx:id="btnAdd"/>
    <Button styleClass="btn-warning" text="✏  Edit"    onAction="#handleEdit"   fx:id="btnEdit"   disable="true"/>
    <Button styleClass="btn-danger"  text="🗑  Delete"  onAction="#handleDelete" fx:id="btnDelete" disable="true"/>
    <Button styleClass="btn-outline" text="⟳  Refresh" onAction="#handleRefresh"/>
  </HBox>
  <Separator style="-fx-background-color:#d8dce8;"/>

  <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding:10 28 8 28;">
    <TextField fx:id="txtSearch" styleClass="search-field" promptText="Search by code or name…" prefWidth="250"/>
    <ComboBox  fx:id="cmbSearchStatus" styleClass="filter-combo" promptText="All Status" prefWidth="130"/>
    <DatePicker fx:id="dpSearchFrom" styleClass="filter-date" promptText="Active from" prefWidth="130"/>
    <DatePicker fx:id="dpSearchTo"   styleClass="filter-date" promptText="Active to"   prefWidth="130"/>
    <Button styleClass="btn-primary" text="Search" onAction="#handleSearch"
            style="-fx-padding:7 14 7 14;"/>
  </HBox>

  <VBox VBox.vgrow="ALWAYS" style="-fx-padding:0 28 14 28;">
    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
      <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

        <TableView fx:id="promoTable" styleClass="table-view" style="-fx-hbar-policy:never;">
        <columns>
          <TableColumn fx:id="colId"     text="ID"           prefWidth="55"/>
          <TableColumn fx:id="colCode"   text="Code"         prefWidth="130"/>
          <TableColumn fx:id="colName"   text="Name"         prefWidth="180"/>
          <TableColumn fx:id="colType"   text="Type"         prefWidth="110"/>
          <TableColumn fx:id="colValue"  text="Value"        prefWidth="100"/>
          <TableColumn fx:id="colDates"  text="Valid Dates"  prefWidth="200"/>
          <TableColumn fx:id="colUsage"  text="Usage Limit"  prefWidth="110"/>
          <TableColumn fx:id="colStatus" text="Status"       prefWidth="110"/>
        </columns>
        <placeholder><Label text="No promotions found." style="-fx-text-fill:#8a93b2;"/></placeholder>
      </TableView>

      </ScrollPane>
      <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ" style="-fx-text-fill:#4a7cff;-fx-font-size:14px;"/>
        <Label fx:id="statusBarLabel" styleClass="status-bar-label" text="Loading…"/>
      </HBox>
    </VBox>
  </VBox>
</VBox>
