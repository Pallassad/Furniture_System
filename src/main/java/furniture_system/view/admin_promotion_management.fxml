<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.AdminPromotionController"
      stylesheets="@/furniture_system/resources/css/admin.css"
      styleClass="content-root"
      spacing="14">
    <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

    <!-- ── Page Header ──────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🎫 Promotion Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAdd"     text="➕  Add Promotion"  onAction="#handleAdd"     styleClass="btn-primary"/>
        <Button fx:id="btnEdit"    text="✏  Edit"            onAction="#handleEdit"    styleClass="btn-warning"/>
        <Button fx:id="btnDisable" text="🚫  Disable"        onAction="#handleDisable" styleClass="btn-danger"/>
        <Button fx:id="btnDelete"  text="🗑  Delete permanently" onAction="#handleDelete"  styleClass="btn-danger"/>
        <Button                    text="⟳  Refresh"         onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>

    <Separator styleClass="separator"/>

    <!-- ── Search Bar ───────────────────────────────────────────────────── -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch" styleClass="login-field"
                   promptText="🔍 Search by code or name…"
                   HBox.hgrow="ALWAYS"/>
        <Label text="Status:" style="-fx-font-weight:bold;-fx-font-size:12px;"/>
        <ComboBox fx:id="cmbSearchStatus" prefWidth="130" styleClass="combo-box"/>
        <Label text="From:" style="-fx-font-weight:bold;-fx-font-size:12px;"/>
        <DatePicker fx:id="dpSearchFrom" prefWidth="138" styleClass="date-picker"/>
        <Label text="To:" style="-fx-font-weight:bold;-fx-font-size:12px;"/>
        <DatePicker fx:id="dpSearchTo" prefWidth="138" styleClass="date-picker"/>
        <Button text="Search" onAction="#handleSearch"  styleClass="btn-primary"/>
        <Button text="Clear"  onAction="#handleRefresh" styleClass="btn-outline"/>
    </HBox>

    <!-- ── Promotion Table ──────────────────────────────────────────────── -->
    <TableView fx:id="promoTable" VBox.vgrow="ALWAYS" styleClass="table-view"
               tableMenuButtonVisible="true">
        <columns>
            <TableColumn fx:id="colId"     text="ID"           prefWidth="55"/>
            <TableColumn fx:id="colCode"   text="Code"         prefWidth="120"/>
            <TableColumn fx:id="colName"   text="Name"         prefWidth="200"/>
            <TableColumn fx:id="colType"   text="Type"         prefWidth="90"/>
            <TableColumn fx:id="colValue"  text="Value"        prefWidth="110"/>
            <TableColumn fx:id="colDates"  text="Period"       prefWidth="190"/>
            <TableColumn fx:id="colUsage"  text="Used / Limit" prefWidth="105"/>
            <TableColumn fx:id="colStatus" text="Status"       prefWidth="105"/>
        </columns>
        <placeholder>
            <Label text="No promotions found." styleClass="table-placeholder"/>
        </placeholder>
    </TableView>

    <!-- ── Status Bar ───────────────────────────────────────────────────── -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ"/>
        <Label fx:id="statusBarLabel" text="Ready." styleClass="status-label"/>
    </HBox>
</VBox>
