<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<StackPane xmlns:fx="http://javafx.com/fxml"
           xmlns="http://javafx.com/javafx"
           fx:controller="furniture_system.controller.LoginController"
           stylesheets="@../resources/css/login.css"
           prefWidth="780" prefHeight="560"
           minWidth="780" maxWidth="780"
           minHeight="560" maxHeight="560">

  <!-- ── Background gradient panel ─────────────────────────── -->
  <HBox styleClass="login-root" alignment="CENTER">

    <!-- LEFT PANEL -->
    <VBox styleClass="panel-left" spacing="0">
      <VBox styleClass="brand-block" spacing="10">
        <Label styleClass="brand-icon" text="🛋"/>
        <Label styleClass="brand-name" text="Fair Deal&#10;Furniture"/>
        <Label styleClass="brand-tagline"
               text="Internal management system&#10;for staff and administrators."
               wrapText="true"/>
      </VBox>

      <Region VBox.vgrow="ALWAYS"/>

      <VBox styleClass="feature-list" spacing="12">
        <HBox alignment="CENTER_LEFT" spacing="10">
          <Region styleClass="feature-dot"/>
          <Label styleClass="feature-item" text="Order &amp; inventory tracking"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="10">
          <Region styleClass="feature-dot"/>
          <Label styleClass="feature-item" text="Customer &amp; employee records"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="10">
          <Region styleClass="feature-dot"/>
          <Label styleClass="feature-item" text="Salary &amp; warranty management"/>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="10">
          <Region styleClass="feature-dot"/>
          <Label styleClass="feature-item" text="Role-based access control"/>
        </HBox>
      </VBox>

      <Region VBox.vgrow="ALWAYS"/>

      <Label styleClass="panel-footer"
             text="Fair Deal Furniture System&#10;© 2026 — All rights reserved"
             wrapText="true"/>
    </VBox>

    <!-- RIGHT PANEL -->
    <VBox styleClass="panel-right" alignment="CENTER" HBox.hgrow="ALWAYS">
      <padding><Insets top="52" right="48" bottom="52" left="48"/></padding>

      <!-- StackPane so all panes occupy the same space -->
      <StackPane VBox.vgrow="ALWAYS">

        <!-- ══ PANE 1: Login ════════════════════════════════════ -->
        <VBox fx:id="loginPane" styleClass="form-pane" spacing="0" alignment="TOP_LEFT">

          <Label styleClass="pane-title"    text="Welcome back"/>
          <Label styleClass="pane-subtitle" text="Sign in to your account to continue."
                 wrapText="true"/>
          <Region prefHeight="24"/>

          <Label styleClass="field-label" text="Username"/>
          <TextField fx:id="usernameField"
                     styleClass="form-field"
                     promptText="Enter your username"/>
          <Region prefHeight="14"/>

          <Label styleClass="field-label" text="Password"/>
          <PasswordField fx:id="passwordField"
                         styleClass="form-field"
                         promptText="Enter your password"/>
          <Region prefHeight="10"/>

          <!-- Error label (hidden initially) -->
          <Label fx:id="errorLabel"
                 styleClass="error-label"
                 text=""
                 wrapText="true"
                 visible="false" managed="false"/>
          <Region prefHeight="6"/>

          <Button fx:id="loginButton"
                  styleClass="btn-main"
                  text="Sign In →"
                  onAction="#handleLogin"
                  maxWidth="Infinity"/>

          <Region prefHeight="18"/>
          <Separator styleClass="form-divider"/>
          <Region prefHeight="14"/>

          <HBox alignment="CENTER_LEFT" spacing="0">
            <Button styleClass="btn-ghost"
                    text="Forgot password?"
                    onAction="#handleForgotPassword"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button styleClass="btn-exit"
                    text="Exit"
                    onAction="#handleExit"/>
          </HBox>
        </VBox>

        <!-- ══ PANE 2: Forgot — enter email ═════════════════════ -->
        <VBox fx:id="step1Pane" styleClass="form-pane" spacing="0" alignment="TOP_LEFT"
              visible="false" managed="false">

          <HBox styleClass="step-indicator" spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="step-dot step-active"/>
            <Region styleClass="step-dot"/>
            <Region styleClass="step-dot"/>
            <Label  styleClass="step-label" text="STEP 1 OF 3 — VERIFY EMAIL"/>
          </HBox>
          <Region prefHeight="16"/>

          <Label styleClass="pane-title"    text="Reset Password"/>
          <Label styleClass="pane-subtitle"
                 text="Enter the email address linked to your account and we'll send you a reset code."
                 wrapText="true"/>
          <Region prefHeight="24"/>

          <Label styleClass="field-label" text="Email Address"/>
          <TextField fx:id="emailField"
                     styleClass="form-field"
                     promptText="your@email.com"/>
          <Region prefHeight="10"/>

          <Label fx:id="step1ErrorLabel"
                 styleClass="error-label"
                 text=""
                 wrapText="true"
                 visible="false" managed="false"/>
          <Region prefHeight="6"/>

          <Button fx:id="sendCodeButton"
                  styleClass="btn-accent"
                  text="Send Code →"
                  onAction="#handleSendCode"
                  maxWidth="Infinity"/>

          <Region prefHeight="18"/>
          <Separator styleClass="form-divider"/>
          <Region prefHeight="14"/>

          <Button styleClass="btn-ghost"
                  text="← Back to Login"
                  onAction="#handleBackToLogin"/>
        </VBox>

        <!-- ══ PANE 3: OTP + new password ══════════════════════ -->
        <VBox fx:id="step2Pane" styleClass="form-pane" spacing="0" alignment="TOP_LEFT"
              visible="false" managed="false">

          <HBox styleClass="step-indicator" spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="step-dot step-done"/>
            <Region styleClass="step-dot step-active"/>
            <Region styleClass="step-dot"/>
            <Label  styleClass="step-label" text="STEP 2 OF 3 — NEW PASSWORD"/>
          </HBox>
          <Region prefHeight="16"/>

          <Label styleClass="pane-title"    text="Enter Reset Code"/>
          <Label fx:id="step2InfoLabel"
                 styleClass="pane-subtitle info-label"
                 text="Check your inbox. Code expires in 15 minutes."
                 wrapText="true"/>
          <Region prefHeight="20"/>

          <Label styleClass="field-label" text="Reset Code"/>
          <TextField fx:id="otpField"
                     styleClass="form-field otp-field"
                     promptText="6-digit code from email"/>
          <Region prefHeight="12"/>

          <Label styleClass="field-label" text="New Password"/>
          <PasswordField fx:id="newPasswordField"
                         styleClass="form-field"
                         promptText="Min 6 characters"/>
          <Region prefHeight="12"/>

          <Label styleClass="field-label" text="Confirm Password"/>
          <PasswordField fx:id="confirmPasswordField"
                         styleClass="form-field"
                         promptText="Repeat new password"/>
          <Region prefHeight="4"/>

          <Label fx:id="passwordMatchLabel"
                 styleClass="match-label"
                 text=""
                 visible="false" managed="false"/>
          <Region prefHeight="8"/>

          <Label fx:id="step2ErrorLabel"
                 styleClass="error-label"
                 text=""
                 wrapText="true"
                 visible="false" managed="false"/>
          <Region prefHeight="6"/>

          <Button fx:id="resetButton"
                  styleClass="btn-accent"
                  text="Reset Password"
                  onAction="#handleResetPassword"
                  maxWidth="Infinity"/>

          <Region prefHeight="18"/>
          <Separator styleClass="form-divider"/>
          <Region prefHeight="14"/>

          <Button styleClass="btn-ghost"
                  text="← Back"
                  onAction="#handleBackToStep1"/>
        </VBox>

        <!-- ══ PANE 4: Success ══════════════════════════════════ -->
        <VBox fx:id="step3Pane" styleClass="form-pane" spacing="0" alignment="TOP_LEFT"
              visible="false" managed="false">

          <HBox styleClass="step-indicator" spacing="6" alignment="CENTER_LEFT">
            <Region styleClass="step-dot step-done"/>
            <Region styleClass="step-dot step-done"/>
            <Region styleClass="step-dot step-active"/>
            <Label  styleClass="step-label" text="STEP 3 OF 3 — COMPLETE"/>
          </HBox>
          <Region prefHeight="20"/>

          <Label styleClass="success-icon" text="✓"/>
          <Region prefHeight="14"/>

          <Label styleClass="pane-title success-title" text="Password Reset!"/>
          <Label styleClass="pane-subtitle"
                 text="Your password has been updated. You can now sign in with your new password."
                 wrapText="true"/>
          <Region prefHeight="16"/>

          <!-- Summary grid -->
          <GridPane styleClass="success-detail" hgap="12" vgap="8">
            <Label styleClass="summary-key" text="Account" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Label fx:id="summaryUsername"  styleClass="summary-val" text="—"
                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Label styleClass="summary-key" text="Time"    GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Label fx:id="summaryTime"      styleClass="summary-val" text="—"
                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
          </GridPane>
          <Region prefHeight="20"/>

          <Button styleClass="btn-main"
                  text="← Back to Login"
                  onAction="#handleBackToLogin"
                  maxWidth="Infinity"/>
        </VBox>

      </StackPane><!-- /StackPane -->
    </VBox><!-- /panel-right -->

  </HBox>
</StackPane>
