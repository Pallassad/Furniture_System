<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!--
  login.fxml  -  Login + Forgot Password (Step 1 / 2 / 3)
  Controller  : furniture_system.controller.LoginController

  Pane visibility is controlled by the controller:
    loginPane  - Sign In screen (default, visible on load)
    step1Pane  - Forgot Password: Enter Email
    step2Pane  - Forgot Password: Enter OTP + New Password
    step3Pane  - Forgot Password: Success
-->
<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="furniture_system.controller.LoginController"
           stylesheets="@/furniture_system/resources/css/admin.css"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="0">

        <!-- ═══════════════════════════════════════════════
             HEADER BANNER  (shared across all screens)
             ═══════════════════════════════════════════════ -->
        <VBox alignment="CENTER" spacing="6" styleClass="login-header">
            <Label text="&#129137; Fair Deal Furniture" styleClass="app-title"/>
            <Label text="Store Management System"       styleClass="app-subtitle"/>
        </VBox>

        <!-- ═══════════════════════════════════════════════
             CARD WRAPPER  - only 1 pane visible at a time
             ═══════════════════════════════════════════════ -->
        <StackPane styleClass="login-card" maxWidth="400">
            <padding><Insets top="36" right="40" bottom="36" left="40"/></padding>

            <!-- ─────────────────────────────────────────
                 PANE 0 : SIGN IN
                 ───────────────────────────────────────── -->
            <VBox fx:id="loginPane" alignment="TOP_LEFT" spacing="18"
                  visible="true" managed="true">

                <Label text="Sign In" styleClass="card-title"/>

                <!-- Username -->
                <VBox spacing="4">
                    <Label text="Username" styleClass="field-label"/>
                    <TextField fx:id="usernameField"
                               promptText="Enter your username"
                               styleClass="login-field"/>
                </VBox>

                <!-- Password -->
                <VBox spacing="4">
                    <Label text="Password" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="Enter your password"
                                   styleClass="login-field"/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Forgot password?"
                                onAction="#handleForgotPassword"
                                styleClass="btn-link"/>
                    </HBox>
                </VBox>

                <!-- Error message -->
                <Label fx:id="errorLabel" text="" styleClass="error-label"
                       wrapText="true" maxWidth="320"
                       visible="false" managed="false"/>

                <Separator styleClass="fp-separator"/>

                <!-- Action buttons -->
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="Exit"
                            onAction="#handleExit"
                            styleClass="btn-secondary"/>
                    <Button fx:id="loginButton" text="Login"
                            defaultButton="true"
                            onAction="#handleLogin"
                            styleClass="btn-primary"/>
                </HBox>

            </VBox>

            <!-- ─────────────────────────────────────────
                 PANE 1 : FORGOT PASSWORD - STEP 1
                          Enter Email
                 ───────────────────────────────────────── -->
            <VBox fx:id="step1Pane" alignment="TOP_LEFT" spacing="14"
                  visible="false" managed="false">

                <!-- Step indicator dots -->
                <HBox alignment="CENTER" spacing="0" styleClass="steps-bar">
                    <Label text="1" styleClass="step-dot step-active"/>
                    <Region styleClass="step-line"
                            HBox.hgrow="NEVER" prefWidth="48"/>
                    <Label text="2" styleClass="step-dot step-inactive"/>
                    <Region styleClass="step-line"
                            HBox.hgrow="NEVER" prefWidth="48"/>
                    <Label text="3" styleClass="step-dot step-inactive"/>
                </HBox>

                <!-- Step labels -->
                <HBox styleClass="steps-labels">
                    <Label text="Enter Email" styleClass="step-lbl step-lbl-active" HBox.hgrow="ALWAYS"/>
                    <Label text="Reset Code"  styleClass="step-lbl"                 HBox.hgrow="ALWAYS"/>
                    <Label text="Done"        styleClass="step-lbl"                 HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label text="Forgot Password?" styleClass="card-title"/>
                <Label text="Enter your registered email to receive a reset code."
                       styleClass="card-subtitle" wrapText="true"/>

                <!-- Info box -->
                <HBox styleClass="info-box" spacing="8" alignment="CENTER_LEFT">
                    <Label text="&#128274;" styleClass="info-icon"/>
                    <Label text="We will send a 6-digit OTP code to your email address."
                           styleClass="info-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Email field -->
                <VBox spacing="4">
                    <HBox spacing="2">
                        <Label text="Email Address" styleClass="field-label"/>
                        <Label text="*"             styleClass="field-req"/>
                    </HBox>
                    <TextField fx:id="emailField"
                               promptText="your@email.com"
                               styleClass="login-field"/>
                    <Label text="Enter the email linked to your account."
                           styleClass="hint-label"/>
                </VBox>

                <!-- Error message step 1 -->
                <Label fx:id="step1ErrorLabel" text="" styleClass="error-label"
                       wrapText="true" maxWidth="320"
                       visible="false" managed="false"/>

                <Separator styleClass="fp-separator"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="&#8592; Back to Login"
                            onAction="#handleBackToLogin"
                            styleClass="btn-secondary"/>
                    <Button fx:id="sendCodeButton" text="Send Code &#8594;"
                            onAction="#handleSendCode"
                            styleClass="btn-primary"/>
                </HBox>

            </VBox>

            <!-- ─────────────────────────────────────────
                 PANE 2 : FORGOT PASSWORD - STEP 2
                          Enter OTP + New Password
                 ───────────────────────────────────────── -->
            <VBox fx:id="step2Pane" alignment="TOP_LEFT" spacing="14"
                  visible="false" managed="false">

                <!-- Step indicator dots -->
                <HBox alignment="CENTER" spacing="0" styleClass="steps-bar">
                    <Label text="&#10003;" styleClass="step-dot step-done"/>
                    <Region styleClass="step-line step-line-done"
                            HBox.hgrow="NEVER" prefWidth="48"/>
                    <Label text="2"        styleClass="step-dot step-active"/>
                    <Region styleClass="step-line"
                            HBox.hgrow="NEVER" prefWidth="48"/>
                    <Label text="3"        styleClass="step-dot step-inactive"/>
                </HBox>

                <!-- Step labels -->
                <HBox styleClass="steps-labels">
                    <Label text="Enter Email" styleClass="step-lbl"                 HBox.hgrow="ALWAYS"/>
                    <Label text="Reset Code"  styleClass="step-lbl step-lbl-active" HBox.hgrow="ALWAYS"/>
                    <Label text="Done"        styleClass="step-lbl"                 HBox.hgrow="ALWAYS"/>
                </HBox>

                <Label text="Enter Reset Code" styleClass="card-title"/>
                <Label text="A 6-digit code was sent to your email address."
                       styleClass="card-subtitle" wrapText="true"/>

                <!-- Info box -->
                <HBox styleClass="info-box" spacing="8" alignment="CENTER_LEFT">
                    <Label text="&#128231;" styleClass="info-icon"/>
                    <Label fx:id="step2InfoLabel"
                           text="Check your inbox. Code expires in 15 minutes."
                           styleClass="info-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- OTP field -->
                <VBox spacing="4">
                    <HBox spacing="2">
                        <Label text="Reset Code" styleClass="field-label"/>
                        <Label text="*"          styleClass="field-req"/>
                    </HBox>
                    <TextField fx:id="otpField"
                               promptText="_ _ _ _ _ _"
                               maxWidth="320"
                               styleClass="login-field otp-field"/>
                </VBox>

                <!-- New password -->
                <VBox spacing="4">
                    <HBox spacing="2">
                        <Label text="New Password" styleClass="field-label"/>
                        <Label text="*"            styleClass="field-req"/>
                    </HBox>
                    <PasswordField fx:id="newPasswordField"
                                   promptText="Enter new password"
                                   styleClass="login-field"/>
                </VBox>

                <!-- Confirm password -->
                <VBox spacing="4">
                    <HBox spacing="2">
                        <Label text="Confirm Password" styleClass="field-label"/>
                        <Label text="*"                styleClass="field-req"/>
                    </HBox>
                    <PasswordField fx:id="confirmPasswordField"
                                   promptText="Re-enter new password"
                                   styleClass="login-field"/>
                    <Label fx:id="passwordMatchLabel" text=""
                           styleClass="hint-label"
                           visible="false" managed="false"/>
                </VBox>

                <!-- Error message step 2 -->
                <Label fx:id="step2ErrorLabel" text="" styleClass="error-label"
                       wrapText="true" maxWidth="320"
                       visible="false" managed="false"/>

                <Separator styleClass="fp-separator"/>

                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="&#8592; Back"
                            onAction="#handleBackToStep1"
                            styleClass="btn-secondary"/>
                    <Button fx:id="resetButton" text="Reset Password"
                            onAction="#handleResetPassword"
                            styleClass="btn-primary"/>
                </HBox>

            </VBox>

            <!-- ─────────────────────────────────────────
                 PANE 3 : FORGOT PASSWORD - STEP 3
                          Success
                 ───────────────────────────────────────── -->
            <VBox fx:id="step3Pane" alignment="TOP_LEFT" spacing="14"
                  visible="false" managed="false">

                <!-- Step indicator dots -->
                <HBox alignment="CENTER" spacing="0" styleClass="steps-bar">
                    <Label text="&#10003;" styleClass="step-dot step-done"/>
                    <Region styleClass="step-line step-line-done"
                            HBox.hgrow="NEVER" prefWidth="48"/>
                    <Label text="&#10003;" styleClass="step-dot step-done"/>
                    <Region styleClass="step-line step-line-done"
                            HBox.hgrow="NEVER" prefWidth="48"/>
                    <Label text="&#10003;" styleClass="step-dot step-success"/>
                </HBox>

                <!-- Step labels -->
                <HBox styleClass="steps-labels">
                    <Label text="Enter Email" styleClass="step-lbl"                  HBox.hgrow="ALWAYS"/>
                    <Label text="Reset Code"  styleClass="step-lbl"                  HBox.hgrow="ALWAYS"/>
                    <Label text="Done"        styleClass="step-lbl step-lbl-success" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Success icon -->
                <Label text="&#10003;" styleClass="success-circle"
                       alignment="CENTER" maxWidth="Infinity"/>

                <Label text="Password Reset Successful!" styleClass="card-title"
                       alignment="CENTER" maxWidth="Infinity"/>
                <Label text="Your password has been updated successfully."
                       styleClass="card-subtitle" wrapText="true"
                       alignment="CENTER" maxWidth="Infinity"/>

                <!-- Summary box -->
                <VBox styleClass="summary-box" spacing="0">
                    <HBox styleClass="summary-row">
                        <Label text="Account"  styleClass="summary-lbl" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="summaryUsername" text="-" styleClass="summary-val"/>
                    </HBox>
                    <Separator styleClass="summary-sep"/>
                    <HBox styleClass="summary-row">
                        <Label text="Status"   styleClass="summary-lbl" HBox.hgrow="ALWAYS"/>
                        <Label text="&#10003; Updated" styleClass="summary-val summary-ok"/>
                    </HBox>
                    <Separator styleClass="summary-sep"/>
                    <HBox styleClass="summary-row">
                        <Label text="Time"     styleClass="summary-lbl" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="summaryTime" text="Just now" styleClass="summary-val"/>
                    </HBox>
                </VBox>

                <!-- Tip box -->
                <HBox styleClass="tip-box" spacing="8" alignment="TOP_LEFT">
                    <Label text="&#128161;" styleClass="info-icon"/>
                    <Label text="For security, avoid reusing old passwords. Use a mix of letters, numbers and symbols."
                           styleClass="info-text" wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Separator styleClass="fp-separator"/>

                <HBox alignment="CENTER">
                    <Button text="Back to Login &#8594;"
                            onAction="#handleBackToLogin"
                            styleClass="btn-primary"/>
                </HBox>

            </VBox>

        </StackPane>
        <!-- end card wrapper -->

        <!-- ═══════════════════════════════════════════════
             FOOTER
             ═══════════════════════════════════════════════ -->
        <Label text="&#169; 2026 Fair Deal Store  |  v1.0"
               styleClass="login-footer"/>

    </VBox>

</StackPane>
