<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx"
      fx:controller="furniture_system.controller.AdminDeliveryAddressController"
      stylesheets="@../resources/css/admin.css" spacing="0"
      style="-fx-background-color:#eef0f5;">

  <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:20 28 14 28;">
    <Label styleClass="page-title" text="📍  Delivery Addresses"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button styleClass="btn-primary" text="➕  Add"          onAction="#onAdd"        fx:id="btnAdd"/>
    <Button styleClass="btn-warning" text="✏  Edit"         onAction="#onEdit"       fx:id="btnEdit"       disable="true"/>
    <Button styleClass="btn-info"    text="⭐  Set Default"  onAction="#onSetDefault" fx:id="btnSetDefault" disable="true"/>
    <Button styleClass="btn-danger"  text="🗑  Delete"       onAction="#onDelete"     fx:id="btnDelete"     disable="true"/>
    <Button styleClass="btn-outline" text="⟳  Refresh"      onAction="#handleRefresh"/>
  </HBox>
  <Separator style="-fx-background-color:#d8dce8;"/>

  <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding:10 28 8 28;">
    <TextField fx:id="txtSearch" styleClass="search-field"
               promptText="Search by customer, receiver, city…" prefWidth="320"/>
    <Button styleClass="btn-primary" text="Search" onAction="#onSearch"
            style="-fx-padding:7 14 7 14;"/>
  </HBox>

  <VBox VBox.vgrow="ALWAYS" style="-fx-padding:0 28 14 28;">
    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
      <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

        <TableView fx:id="tblAddresses" styleClass="table-view">
        <columns>
          <TableColumn fx:id="colId"       text="ID"            prefWidth="55"/>
          <TableColumn fx:id="colCustomer" text="Customer"      prefWidth="160"/>
          <TableColumn fx:id="colReceiver" text="Receiver Name" prefWidth="160"/>
          <TableColumn fx:id="colPhone"    text="Phone"         prefWidth="120"/>
          <TableColumn fx:id="colAddress"  text="Address Line"  prefWidth="200"/>
          <TableColumn fx:id="colDistrict" text="District"      prefWidth="110"/>
          <TableColumn fx:id="colCity"     text="City"          prefWidth="110"/>
          <TableColumn fx:id="colDefault"  text="Default"       prefWidth="80"/>
          <TableColumn fx:id="colStatus"   text="Status"        prefWidth="110"/>
        </columns>
        <placeholder><Label text="No addresses found." style="-fx-text-fill:#8a93b2;"/></placeholder>
      </TableView>

      </ScrollPane>
      <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ" style="-fx-text-fill:#4a7cff;-fx-font-size:14px;"/>
        <Label fx:id="lblStatus" styleClass="status-bar-label" text="Loading…"/>
      </HBox>
    </VBox>
    <!-- Stats row below table -->
    <HBox spacing="24" style="-fx-padding:8 0 0 4;">
      <Label fx:id="lblTopCity"      styleClass="status-bar-label" text="Top City: —"/>
      <Label fx:id="lblDefaultRate"  styleClass="status-bar-label" text="Default address used: —"/>
    </HBox>
  </VBox>
</VBox>
