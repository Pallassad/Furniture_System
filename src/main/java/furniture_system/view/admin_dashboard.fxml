<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            xmlns="http://javafx.com/javafx"
            fx:controller="furniture_system.controller.AdminDashboardController"
            stylesheets="@../resources/css/admin.css"
            prefWidth="1280" prefHeight="760">

    <!-- TOPBAR -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16" prefHeight="58">
        
            <!-- Bên trái: Logo + Title -->
            <Region styleClass="topbar-logo" prefWidth="22" prefHeight="22"/>
            <Label styleClass="topbar-title" text="Fair Deal – Admin Dashboard" HBox.hgrow="ALWAYS"/>

            <!-- Bên phải: Role + Welcome + Logout (sát phải) -->
            <HBox alignment="CENTER_RIGHT" spacing="14" HBox.hgrow="NEVER">
                <Label styleClass="topbar-role" text="ADMIN"/>
                <Label fx:id="lblUsername" styleClass="topbar-welcome" text="Welcome, admin"/>
                <Button styleClass="btn-logout" text="Logout" onAction="#handleLogout"/>
            </HBox>
        
        </HBox>
    </top>

    <!-- BODY -->
    <center>
        <HBox>
            <!-- SIDEBAR -->
            <VBox styleClass="sidebar" spacing="0">
                <Label styleClass="menu-label" text="MENU"/>
                <Region styleClass="sidebar-separator" maxHeight="1" VBox.vgrow="NEVER"/>
                <Button fx:id="btnReports"         styleClass="nav-btn" text="📊  Summary Reports"      onAction="#showReports"                   maxWidth="Infinity"/>
                <Region styleClass="sidebar-separator" maxHeight="1" VBox.vgrow="NEVER"/>
                <Button fx:id="btnAuth"            styleClass="nav-btn" text="🔐  Auth &amp; Authorization"   onAction="#showAuthManagement"            maxWidth="Infinity"/>
                <Button fx:id="btnEmployee"        styleClass="nav-btn" text="👥  Employee Management"   onAction="#showEmployeeManagement"        maxWidth="Infinity"/>
                <Button fx:id="btnCustomer"        styleClass="nav-btn" text="🙍  Customer Management"   onAction="#showCustomerManagement"        maxWidth="Infinity"/>
                <Button fx:id="btnProduct"         styleClass="nav-btn" text="🛋  Furniture Management"  onAction="#showProductManagement"         maxWidth="Infinity"/>
                <Button fx:id="btnFurnitureType"   styleClass="nav-btn" text="🪑  Furniture Types"        onAction="#showFurnitureTypeManagement"   maxWidth="Infinity"/>
                <Button fx:id="btnOrders"          styleClass="nav-btn" text="📦  Orders"                 onAction="#showOrders"                    maxWidth="Infinity"/>
                <Button fx:id="btnPromotion"       styleClass="nav-btn" text="🏷  Promotion Management"  onAction="#showPromotionManagement"       maxWidth="Infinity"/>
                <Button fx:id="btnSupplier"        styleClass="nav-btn" text="🏭  Supplier Management"   onAction="#showSupplierManagement"        maxWidth="Infinity"/>
                <Button fx:id="btnStock"           styleClass="nav-btn" text="📈  Stock &amp; Inventory"      onAction="#showStockManagement"           maxWidth="Infinity"/>
                <Button fx:id="btnSalary"          styleClass="nav-btn" text="💰  Salary Management"     onAction="#showSalaryManagement"          maxWidth="Infinity"/>
                <Button fx:id="btnWarranty"        styleClass="nav-btn" text="🔧  Warranty &amp; Repair"      onAction="#showWarrantyManagement"        maxWidth="Infinity"/>
                <Button fx:id="btnDeliveryAddress" styleClass="nav-btn" text="📍  Delivery Addresses"    onAction="#showDeliveryAddressManagement" maxWidth="Infinity"/>
            </VBox>

            <!-- CONTENT AREA -->
            <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS"
                       style="-fx-background-color:#eef0f5;">

                <!-- Default: welcome card + tile grid -->
                <ScrollPane fitToWidth="true"
                            style="-fx-background-color:#eef0f5; -fx-background:#eef0f5; -fx-border-color:transparent;">
                    <VBox spacing="20" style="-fx-padding:24 28 24 28; -fx-background-color:#eef0f5;">

                        <!-- Welcome Card -->
                        <HBox styleClass="welcome-card" alignment="CENTER_LEFT" spacing="20">
                            <Label styleClass="welcome-avatar" text="👤"
                                   prefWidth="52" prefHeight="52" alignment="CENTER"/>
                            <VBox spacing="4">
                                <Label styleClass="welcome-title"    text="Welcome back, Admin"/>
                                <Label styleClass="welcome-subtitle" text="Fair Deal Furniture Management System  ·  Thursday, 26 March 2026"/>
                            </VBox>
                        </HBox>

                        <!-- Tile Grid -->
                        <GridPane hgap="14" vgap="14">

                            <!-- Row 0 -->
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showReports"
                                  GridPane.columnIndex="0" GridPane.rowIndex="0" prefWidth="185">
                                <Label styleClass="tile-icon" text="📊"/>
                                <Label styleClass="tile-label" text="Summary Reports"/>
                                <Label styleClass="tile-desc" text="KPI overview: orders, revenue, customers, payroll" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showAuthManagement"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="185">
                                <Label styleClass="tile-icon" text="🔐"/>
                                <Label styleClass="tile-label" text="Auth &amp; Authorization"/>
                                <Label styleClass="tile-desc" text="Manage user accounts, roles and login status" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showEmployeeManagement"
                                  GridPane.columnIndex="2" GridPane.rowIndex="0" prefWidth="185">
                                <Label styleClass="tile-icon" text="👥"/>
                                <Label styleClass="tile-label" text="Employee Management"/>
                                <Label styleClass="tile-desc" text="Add, edit, deactivate staff records" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showCustomerManagement"
                                  GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="185">
                                <Label styleClass="tile-icon" text="🙍"/>
                                <Label styleClass="tile-label" text="Customer Management"/>
                                <Label styleClass="tile-desc" text="View and manage registered customers" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showProductManagement"
                                  GridPane.columnIndex="4" GridPane.rowIndex="0" prefWidth="185">
                                <Label styleClass="tile-icon" text="🛋"/>
                                <Label styleClass="tile-label" text="Furniture Management"/>
                                <Label styleClass="tile-desc" text="Product catalog, pricing, warranty periods" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showFurnitureTypeManagement"
                                  GridPane.columnIndex="5" GridPane.rowIndex="0" prefWidth="185">
                                <Label styleClass="tile-icon" text="🪑"/>
                                <Label styleClass="tile-label" text="Furniture Types"/>
                                <Label styleClass="tile-desc" text="Product category definitions" wrapText="true"/>
                            </VBox>

                            <!-- Row 1 -->
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showOrders"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1" prefWidth="185">
                                <Label styleClass="tile-icon" text="📦"/>
                                <Label styleClass="tile-label" text="Orders"/>
                                <Label styleClass="tile-desc" text="Track and update all customer orders" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showPromotionManagement"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="185">
                                <Label styleClass="tile-icon" text="🏷"/>
                                <Label styleClass="tile-label" text="Promotion Management"/>
                                <Label styleClass="tile-desc" text="Discount codes, validity and usage limits" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showSupplierManagement"
                                  GridPane.columnIndex="2" GridPane.rowIndex="1" prefWidth="185">
                                <Label styleClass="tile-icon" text="🏭"/>
                                <Label styleClass="tile-label" text="Supplier Management"/>
                                <Label styleClass="tile-desc" text="Supplier contacts and product links" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showStockManagement"
                                  GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="185">
                                <Label styleClass="tile-icon" text="📈"/>
                                <Label styleClass="tile-label" text="Stock &amp; Inventory"/>
                                <Label styleClass="tile-desc" text="Stock levels, reorder alerts, movement log" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showSalaryManagement"
                                  GridPane.columnIndex="4" GridPane.rowIndex="1" prefWidth="185">
                                <Label styleClass="tile-icon" text="💰"/>
                                <Label styleClass="tile-label" text="Salary Management"/>
                                <Label styleClass="tile-desc" text="Payroll records, bonuses and deductions" wrapText="true"/>
                            </VBox>
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showWarrantyManagement"
                                  GridPane.columnIndex="5" GridPane.rowIndex="1" prefWidth="185">
                                <Label styleClass="tile-icon" text="🔧"/>
                                <Label styleClass="tile-label" text="Warranty &amp; Repair"/>
                                <Label styleClass="tile-desc" text="Warranty tickets, repair status and costs" wrapText="true"/>
                            </VBox>

                            <!-- Row 2 -->
                            <VBox styleClass="tile" spacing="8" onMouseClicked="#showDeliveryAddressManagement"
                                  GridPane.columnIndex="0" GridPane.rowIndex="2" prefWidth="185">
                                <Label styleClass="tile-icon" text="📍"/>
                                <Label styleClass="tile-label" text="Delivery Addresses"/>
                                <Label styleClass="tile-desc" text="Manage customer delivery addresses" wrapText="true"/>
                            </VBox>

                        </GridPane>
                    </VBox>
                </ScrollPane>

            </StackPane>
        </HBox>
    </center>
</BorderPane>
