<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml" xmlns="http://javafx.com/javafx"
      fx:controller="furniture_system.controller.AdminOrderController"
      stylesheets="@../resources/css/admin.css" spacing="0"
      style="-fx-background-color:#eef0f5;">

  <!-- Page Header -->
  <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding:20 28 14 28;">
    <Label styleClass="page-title" text="📦  Order Management"/>
    <Region HBox.hgrow="ALWAYS"/>
    <Button fx:id="btnViewDetail"    styleClass="btn-info"    text="🔍  Detail"        onAction="#handleViewDetail"    disable="true"/>
    <Button fx:id="btnUpdateStatus"  styleClass="btn-warning" text="✏  Update Status" onAction="#handleUpdateStatus"  disable="true"/>
    <Button fx:id="btnManageBilling" styleClass="btn-success" text="💳  Billing"        onAction="#handleManageBilling" disable="true"/>
    <Button fx:id="btnDeleteOrder"   styleClass="btn-danger"  text="🗑  Delete"         onAction="#handleDeleteOrder"   disable="true"/>
    <Button                          styleClass="btn-outline" text="⟳  Refresh"         onAction="#onRefresh"/>
  </HBox>
  <Separator style="-fx-background-color:#d8dce8;"/>

  <!-- Search Row -->
  <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding:10 28 8 28;">
    <TextField fx:id="txtSearch" styleClass="search-field"
               promptText="🔍  Search by Order ID, Customer, Employee, Status…"
               onAction="#onSearch" HBox.hgrow="ALWAYS"/>
    <Button styleClass="btn-primary" text="🔍 Search" onAction="#onSearch"
            style="-fx-padding:7 14 7 14;"/>
    <Button styleClass="btn-outline" text="✕ Reset"   onAction="#onReset"
            style="-fx-padding:7 14 7 14;"/>
  </HBox>

  <!-- Table -->
  <VBox VBox.vgrow="ALWAYS" style="-fx-padding:0 28 14 28;">
    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
      <ScrollPane VBox.vgrow="ALWAYS" fitToHeight="true" fitToWidth="false"
           hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
           style="-fx-background-color:transparent; -fx-border-color:transparent; -fx-padding:0;">

        <TableView fx:id="tblOrders" styleClass="table-view" style="-fx-hbar-policy:never;">
        <columns>
          <TableColumn fx:id="colOrderId"  text="Order ID"    prefWidth="90"/>
          <TableColumn fx:id="colCustomer" text="Customer"    prefWidth="180"/>
          <TableColumn fx:id="colEmployee" text="Employee"    prefWidth="150"/>
          <TableColumn fx:id="colDate"     text="Date"        prefWidth="155"/>
          <TableColumn fx:id="colStatus"   text="Status"      prefWidth="110"/>
          <TableColumn fx:id="colFinal"    text="Final (VND)" prefWidth="140"/>
        </columns>
        <placeholder><Label text="No orders found." style="-fx-text-fill:#8a93b2;"/></placeholder>
      </TableView>

      </ScrollPane>
      <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="ℹ" style="-fx-text-fill:#4a7cff;"/>
        <Label fx:id="statusBarLabel" styleClass="status-bar-label" text="Loading…"/>
      </HBox>
    </VBox>
  </VBox>
</VBox>
