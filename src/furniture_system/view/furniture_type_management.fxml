<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="furniture_system.controller.FurnitureTypeController"
            styleClass="content-root"
            stylesheets="@../resources/css/admin.css"
            prefWidth="1000" prefHeight="680">

    <!-- ── Page Header ──────────────────────────────────────────── -->
    <top>
        <VBox styleClass="content-root">
            <padding><Insets top="20" right="24" bottom="0" left="24"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🪑 Manage Furniture Types" styleClass="page-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="txtSearch"
                           promptText="🔍 Search by name, ID, or status…"
                           prefWidth="270"
                           styleClass="login-field"/>
                <Button text="Search" onAction="#handleSearch"      styleClass="btn-primary"/>
                <Button text="✕ Clear" onAction="#handleClearSearch" styleClass="btn-secondary"/>
            </HBox>
            <Separator styleClass="separator">
                <VBox.margin><Insets top="14"/></VBox.margin>
            </Separator>
        </VBox>
    </top>

    <!-- ── Table ────────────────────────────────────────────────── -->
    <center>
        <TableView fx:id="tableView" styleClass="table-view">
            <BorderPane.margin><Insets top="10" right="18" bottom="6" left="18"/></BorderPane.margin>
            <columns>
                <TableColumn fx:id="colId"          text="ID"           prefWidth="55"/>
                <TableColumn fx:id="colName"        text="Type Name"    prefWidth="200"/>
                <TableColumn fx:id="colDescription" text="Description"  prefWidth="290"/>
                <TableColumn fx:id="colStatus"      text="Status"       prefWidth="110"/>
                <TableColumn fx:id="colCreatedAt"   text="Created Date" prefWidth="135"/>
                <TableColumn fx:id="colActions"     text="Actions"      prefWidth="175"/>
            </columns>
            <placeholder>
                <Label text="No furniture types found." styleClass="table-placeholder"/>
            </placeholder>
        </TableView>
    </center>

    <!-- ── Form (Bottom) ────────────────────────────────────────── -->
    <bottom>
        <VBox spacing="10" styleClass="action-pane">
            <padding><Insets top="16" right="22" bottom="18" left="22"/></padding>

            <Label fx:id="lblFormTitle" text="➕  Add New Furniture Type"
                   styleClass="page-title"/>

            <Label fx:id="lblError" styleClass="error-label" wrapText="true"/>

            <GridPane hgap="18" vgap="10">
                <columnConstraints>
                    <ColumnConstraints prefWidth="120" minWidth="100"/>
                    <ColumnConstraints prefWidth="320" hgrow="ALWAYS"/>
                    <ColumnConstraints prefWidth="100" minWidth="90"/>
                    <ColumnConstraints prefWidth="180"/>
                </columnConstraints>

                <Label text="Type Name *" styleClass="field-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtTypeName" styleClass="login-field"
                           promptText="Minimum 2 characters, maximum 100 characters"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Status *" styleClass="field-label"
                       GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <ComboBox fx:id="cmbStatus" prefWidth="170" styleClass="combo-box"
                          GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <Label text="Description" styleClass="field-label"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextArea fx:id="txtDescription" prefHeight="62" wrapText="true"
                          promptText="Short description (optional)…"
                          styleClass="text-area"
                          GridPane.rowIndex="1" GridPane.columnIndex="1"
                          GridPane.columnSpan="3"/>
            </GridPane>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="btnSave"   text="Add"        onAction="#handleSave"
                        styleClass="btn-primary"   prefWidth="120"/>
                <Button fx:id="btnDelete" text="🗑 Delete"  onAction="#handleDelete"
                        styleClass="btn-danger"    prefWidth="120"/>
                <Button fx:id="btnClear"  text="🔄 Refresh" onAction="#handleClear"
                        styleClass="btn-secondary" prefWidth="120"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
