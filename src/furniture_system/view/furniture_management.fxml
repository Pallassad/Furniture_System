<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="furniture_system.controller.AdminFurnitureController"
            styleClass="content-root"
            stylesheets="@../resources/css/admin.css"
            prefWidth="1260" prefHeight="790">

    <center>
        <SplitPane dividerPositions="0.60" orientation="HORIZONTAL"
                   styleClass="content-root">

            <!-- LEFT: Table -->
            <ScrollPane fitToWidth="true" fitToHeight="true" pannable="true">
                <VBox spacing="12">
                    <padding><Insets topRightBottomLeft="20"/></padding>

                    <!-- Page Header -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="🛋 Furniture Management" styleClass="page-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblCount" styleClass="badge-label"/>
                    </HBox>

                    <Separator styleClass="separator"/>

                    <!-- Search Bar -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="txtSearch" styleClass="login-field"
                                   promptText="🔍 Search by name / type / supplier / status / ID…"
                                   HBox.hgrow="ALWAYS"/>
                        <Button text="Search" onAction="#handleSearch"      styleClass="btn-primary"/>
                        <Button text="Clear"  onAction="#handleClearSearch" styleClass="btn-secondary"/>
                    </HBox>

                    <Label fx:id="lblMessage" wrapText="true" maxWidth="Infinity"
                           styleClass="hint-label"/>

                    <TableView fx:id="tableView" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colId"       text="ID"            prefWidth="55"/>
                            <TableColumn fx:id="colName"     text="Product Name"  prefWidth="220"/>
                            <TableColumn fx:id="colType"     text="Category"      prefWidth="140"/>
                            <TableColumn fx:id="colSupplier" text="Supplier"      prefWidth="160"/>
                            <TableColumn fx:id="colPrice"    text="Price"         prefWidth="130"/>
                            <TableColumn fx:id="colWarranty" text="Warranty (mo)" prefWidth="110"/>
                            <TableColumn fx:id="colStatus"   text="Status"        prefWidth="110"/>
                            <TableColumn fx:id="colActions"  text="Actions"       prefWidth="170"/>
                        </columns>
                        <placeholder>
                            <Label text="No products found." styleClass="table-placeholder"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </ScrollPane>

            <!-- RIGHT: Form -->
            <ScrollPane fitToWidth="true" fitToHeight="true" pannable="true">
                <VBox spacing="14">
                    <padding><Insets top="24" right="20" bottom="20" left="20"/></padding>

                    <Label text="Product Details" styleClass="page-title"/>
                    <Separator styleClass="separator"/>

                    <VBox spacing="4">
                        <Label text="Product Name *" styleClass="field-label"/>
                        <TextField fx:id="txtName" styleClass="login-field"
                                   promptText="e.g. Ergonomic Office Chair GX01"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Furniture Type *" styleClass="field-label"/>
                        <ComboBox fx:id="cmbType" styleClass="combo-box"
                                  promptText="— Select category —" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Supplier *" styleClass="field-label"/>
                        <ComboBox fx:id="cmbSupplier" styleClass="combo-box"
                                  promptText="— Select supplier —" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Price (VND) *" styleClass="field-label"/>
                        <TextField fx:id="txtPrice" styleClass="login-field"
                                   promptText="e.g. 1500000"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Warranty (months)" styleClass="field-label"/>
                        <Spinner fx:id="spnWarranty" min="0" max="999" initialValue="0"
                                 editable="true" styleClass="spinner"/>
                    </VBox>

                    <VBox spacing="4">
                        <Label text="Status *" styleClass="field-label"/>
                        <ComboBox fx:id="cmbStatus" styleClass="combo-box" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="4" VBox.vgrow="ALWAYS">
                        <Label text="Description" styleClass="field-label"/>
                        <TextArea fx:id="txtDescription" wrapText="true" prefRowCount="5"
                                  promptText="Optional — product details, materials, dimensions…"
                                  styleClass="text-area"/>
                    </VBox>

                    <Label fx:id="lblFormMessage" wrapText="true" maxWidth="Infinity"
                           styleClass="error-label"/>

                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button fx:id="btnClear"  text="✖ Clear Form"      onAction="#handleClear"
                                styleClass="btn-secondary" prefWidth="120"/>
                        <Button fx:id="btnUpdate" text="✏ Update Product"  onAction="#handleUpdate"
                                styleClass="btn-warning"   prefWidth="140" disable="true"/>
                        <Button fx:id="btnAdd"    text="➕ Add New Product" onAction="#handleAdd"
                                styleClass="btn-primary"   prefWidth="160"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
