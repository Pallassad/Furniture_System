<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.SupplierController"
      spacing="12"
      styleClass="content-root"
      stylesheets="@../resources/css/admin.css"
      style="-fx-padding:20;">

    <Label text="🏭 Supplier Relationship Management" styleClass="page-title"/>

    <!-- ══ Add / Edit Supplier Form ══════════════════════════════════════ -->
    <TitledPane text="Add / Edit Supplier" expanded="true" collapsible="true"
                style="-fx-font-weight:bold;">
        <VBox spacing="10" styleClass="action-pane" style="-fx-padding:16;">
            <GridPane hgap="14" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="100" prefWidth="110"/>
                    <ColumnConstraints hgrow="ALWAYS" prefWidth="200"/>
                    <ColumnConstraints minWidth="100" prefWidth="110"/>
                    <ColumnConstraints hgrow="ALWAYS" prefWidth="200"/>
                </columnConstraints>

                <!-- Row 0 -->
                <Label text="Name *"  styleClass="field-label"
                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="txtName"  promptText="Min 2 characters"
                           styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="Phone *" styleClass="field-label"
                       GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                <TextField fx:id="txtPhone" promptText="9–11 digits, unique"
                           styleClass="login-field"
                           GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                <!-- Row 1 -->
                <Label text="Email"    styleClass="field-label"
                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <TextField fx:id="txtEmail" promptText="Optional, unique"
                           styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Status *" styleClass="field-label"
                       GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                <ComboBox fx:id="cbStatus" maxWidth="Infinity" styleClass="combo-box"
                          GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                <!-- Row 2 -->
                <Label text="Address"  styleClass="field-label"
                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <TextField fx:id="txtAddress" promptText="Optional (max 255 chars)"
                           styleClass="login-field"
                           GridPane.columnIndex="1" GridPane.rowIndex="2"
                           GridPane.columnSpan="3"/>
            </GridPane>

            <Label fx:id="lblFormError" text="" wrapText="true" styleClass="error-label"/>

            <HBox spacing="10">
                <Button fx:id="btnSave"  text="Add Supplier" onAction="#handleSave"
                        styleClass="btn-primary"/>
                <Button fx:id="btnClear" text="Clear"        onAction="#handleClear"
                        styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </TitledPane>

    <!-- ══ Supplier Table ════════════════════════════════════════════════ -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearch"
                   promptText="🔍 Search by name, phone, email, status…"
                   prefWidth="320" styleClass="login-field"/>
        <Button text="Search" onAction="#handleSearch" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="tblSuppliers" prefHeight="200" VBox.vgrow="SOMETIMES"
               styleClass="table-view">
        <placeholder>
            <Label text="No suppliers found." styleClass="table-placeholder"/>
        </placeholder>
        <columns>
            <TableColumn fx:id="colSuppId"      text="ID"      prefWidth="55"/>
            <TableColumn fx:id="colSuppName"    text="Name"    prefWidth="180"/>
            <TableColumn fx:id="colSuppPhone"   text="Phone"   prefWidth="120"/>
            <TableColumn fx:id="colSuppEmail"   text="Email"   prefWidth="190"/>
            <TableColumn fx:id="colSuppAddress" text="Address" prefWidth="200"/>
            <TableColumn fx:id="colSuppStatus"  text="Status"  prefWidth="90"/>
            <TableColumn fx:id="colSuppActions" text="Actions" prefWidth="170"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <!-- ══ Link Supplier ↔ Product ════════════════════════════════════════ -->
    <TitledPane text="Link Supplier to Product (select a supplier above first)"
                expanded="true" collapsible="true"
                style="-fx-font-weight:bold;">
        <VBox spacing="10" styleClass="action-pane" style="-fx-padding:16;">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="Product *"      styleClass="field-label"/>
                <ComboBox fx:id="cbProduct" prefWidth="220" promptText="Choose product…"
                          styleClass="combo-box"/>

                <Label text="Import Price *" styleClass="field-label"/>
                <TextField fx:id="txtImportPrice" promptText="e.g. 250000.00"
                           prefWidth="130" styleClass="login-field"/>

                <Label text="Lead Days"      styleClass="field-label"/>
                <TextField fx:id="txtLeadDays" promptText="0"
                           prefWidth="70" styleClass="login-field"/>

                <Button text="Link Product" onAction="#handleLinkProduct"
                        style="-fx-background-color:#2e7d32; -fx-text-fill:white;
                               -fx-font-weight:bold; -fx-background-radius:6;
                               -fx-padding:8 16; -fx-cursor:hand;"/>
            </HBox>

            <Label fx:id="lblLinkError" text="" styleClass="error-label"/>

            <TableView fx:id="tblLinks" prefHeight="150" VBox.vgrow="NEVER"
                       styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colLinkProduct" text="Product"      prefWidth="240"/>
                    <TableColumn fx:id="colLinkPrice"   text="Import Price" prefWidth="130"/>
                    <TableColumn fx:id="colLinkLead"    text="Lead Days"    prefWidth="100"/>
                    <TableColumn fx:id="colLinkActions" text="Actions"      prefWidth="110"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </TitledPane>

    <!-- Status Bar -->
    <HBox styleClass="status-bar">
        <Label fx:id="lblStatus" text="Ready." styleClass="status-label"/>
    </HBox>

</VBox>
