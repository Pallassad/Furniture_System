<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="furniture_system.controller.EmployeeStockController"
      spacing="12"
      styleClass="content-root"
      stylesheets="@../resources/css/emp.css"
      style="-fx-padding:20;">

    <Label text="📦 Inventory Check" styleClass="page-title"/>

    <!-- Stock Level Table -->
    <TitledPane text="Current Stock Levels" expanded="true" collapsible="false"
                style="-fx-font-weight:bold;">
        <VBox spacing="8" styleClass="action-pane" style="-fx-padding:14;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Orange rows indicate stock below reorder level — notify admin."
                       styleClass="hint-label" style="-fx-text-fill:#e65100;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" onAction="#handleRefresh"
                        styleClass="btn-primary"/>
            </HBox>

            <TableView fx:id="tblStock" prefHeight="280" VBox.vgrow="ALWAYS"
                       styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colProduct" text="Product"       prefWidth="280"/>
                    <TableColumn fx:id="colQty"     text="In Stock"      prefWidth="110"/>
                    <TableColumn fx:id="colReorder" text="Reorder Level" prefWidth="120"/>
                    <TableColumn fx:id="colUpdated" text="Last Updated"  prefWidth="170"/>
                    <TableColumn fx:id="colAlert"   text="Availability"  prefWidth="130"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </TitledPane>

    <!-- Availability Check -->
    <TitledPane text="Check Product Availability for an Order"
                expanded="true" collapsible="true"
                style="-fx-font-weight:bold;">
        <VBox spacing="10" styleClass="action-pane" style="-fx-padding:16;">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="Product:"      styleClass="field-label"/>
                <ComboBox fx:id="cbCheckProduct" prefWidth="240"
                          promptText="Select a product"
                          styleClass="combo-box"/>

                <Label text="Required Qty:" styleClass="field-label"/>
                <TextField fx:id="txRequiredQty" promptText="e.g. 5"
                           prefWidth="90" styleClass="login-field"/>

                <Button text="Check Availability"
                        onAction="#handleCheckAvailability"
                        styleClass="btn-primary"/>
            </HBox>

            <Label fx:id="lblAvailResult" text="" wrapText="true"
                   styleClass="status-bar"
                   style="-fx-font-size:14px; -fx-background-radius:4;"/>
        </VBox>
    </TitledPane>

    <!-- Status Bar -->
    <HBox styleClass="status-bar">
        <Label fx:id="lblStatus" text="Ready." styleClass="status-label"/>
    </HBox>

</VBox>
